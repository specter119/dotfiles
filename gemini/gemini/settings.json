{
  "general": {},
  "ide": {
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    }
  },
  "mcpServers": {
    "fast-context": {
      "command": "bunx",
      "args": [
        "fast-context-mcp"
      ],
      "includeTools": [
        "fast_context_search"
      ],
      "env": {
        "WINDSURF_API_KEY": "{{replace (command_output 'rbw get windsurf-api-key') '\n' ''}}"
      }
    },
    "context7": {
      "command": "bunx",
      "args": [
        "@upstash/context7-mcp",
        "--api-key",
        "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      ],
      "env": {
        "CONTEXT7_KEY": "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      }
    }
  }
}
