{{#if npmrc.registry_auth_npm}}
# Keep shared registry config here, bun reads the deployed ~/.npmrc instead of defining its own registry.
registry=https://{{npmrc.registry_auth_npm}}/
# Auth comes from $XDG_RUNTIME_DIR/dotter/registry-auth-encode, written by .dotter/pre_deploy.sh from registry-auth credentials.
//{{npmrc.registry_auth_npm}}/:_auth={{command_output "cat \"$XDG_RUNTIME_DIR\"/dotter/registry-auth-encode"}}
always-auth=true
{{else}}
registry=https://registry.npmmirror.com
{{/if}}

prefix = ~/.local
