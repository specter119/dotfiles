{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.factory/hooks/session-start.sh\"",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.factory/hooks/user-prompt-submit.sh\"",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.factory/hooks/rtk-rewrite.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Execute"
      }
    ]
  }
}
