{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{replace (command_output "rbw get factory-context7-api-key") "\n" ""}}"
      },
      "tools": ["*"]
    },
    "fast-context": {
      "type": "stdio",
      "command": "bunx",
      "args": ["fast-context-mcp"],
      "env": {
        "WINDSURF_API_KEY": "{{replace (command_output "rbw get factory-windsurf-api-key") "\n" ""}}"
      },
      "tools": ["fast_context_search"]
    }
  }
}
