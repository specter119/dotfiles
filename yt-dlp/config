# Lines starting with # are comments

# Always extract audio
# -x

# extract cookie from browser
# --cookies-from-browser firefox

{{#if enterprise_proxy.url}}--proxy {{enterprise_proxy.url}}{{/if}}

# Do not copy the mtime
--no-mtime

# to specific dir
--output {{yt-dlp.output_dir}}/%(webpage_url_domain)s/%(title)s-%(id)s.%(ext)s

# sub title
--write-auto-sub
--sub-format srt
--sub-lang en

# use aria2
--downloader aria2c
--downloader "dash,m3u8:native"
--downloader-args "aria2c:-j 16 -x 16 -s 16 -k 1M --file-allocation=prealloc{{#if enterprise_proxy.url}} --all-proxy={{enterprise_proxy.url}}{{/if}}"
