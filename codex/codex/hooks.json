{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$HOME/.config/codex/scripts/rtk-rewrite.sh\"",
            "statusMessage": "RTK: Optimizing command output",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
