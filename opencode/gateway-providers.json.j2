[% set providers = {} %]
[% for client_key, client in clients.items() %]
  [% for deployment in deployments %]
    [% set models = {} %]
    [% for model in deployment.models %]
      [% set options = {
        "extra_body": {
          "stream_options": {"include_usage": true}
        }
      } %]
      [% if deployment.name != "azure" and model.reasoning_enabled %]
        [% set _ = options.extra_body.update({"enable_thinking": true}) %]
      [% endif %]
      [% set model_name = model.id %]
      [% if deployment.name == "azure" %]
        [% set model_name = model.id ~ "-sdlc-gs" %]
      [% endif %]
      [% set entry = {
        "name": model_name,
        "options": options,
        "limit": {
          "context": model.context_window,
          "output": model.max_tokens
        }
      } %]
      [% if "image" in model.input %]
        [% set _ = entry.update({
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }) %]
      [% endif %]
      [% if model.reasoning_enabled %]
        [% set _ = entry.update({"reasoning": true}) %]
        [% if model.reasoning_format == "deepseek" %]
          [% set _ = entry.update({"interleaved": {"field": "reasoning_content"}}) %]
        [% endif %]
        [% if model.reasoning_levels %]
          [% set variants = {} %]
          [% for level in model.reasoning_levels %]
            [% set effort = "none" if level == "off" else level %]
            [% set _ = variants.update({effort: {"reasoningEffort": effort}}) %]
          [% endfor %]
          [% set _ = entry.update({"variants": variants}) %]
          [% if deployment.name == "azure" %]
            [% set _ = entry.options.update({"reasoningEffort": "high"}) %]
          [% endif %]
        [% endif %]
      [% endif %]
      [% set _ = models.update({model.id: entry}) %]
    [% endfor %]
    [% set provider_key = client_key ~ "|" ~ deployment.name %]
    [% set _ = providers.update({provider_key: {
      "npm": "@ai-sdk/openai" if deployment.name == "azure" else "@ai-sdk/openai-compatible",
      "name": provider_key,
      "options": {
        "baseURL": deployment.base_url,
        "apiKey": client.api_key,
        "useDeploymentBasedUrls": true,
        "setCacheKey": true
      },
      "models": models
    }}) %]
  [% endfor %]
[% endfor %]
[[ providers | tojson ]]
