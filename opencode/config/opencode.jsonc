{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "packy-codex": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "packy-codex",
      "options": {
        "baseURL": "https://codex-api.packycode.com/v1",
        "apiKey": "{{replace (command_output 'rbw get packy-codex-sub-key') '\n' ''}}"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4"
        }
      }
    },
    "qoder": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "qoder",
      "options": {
        "baseURL": "https://qoder-proxy.worklab.com/v1",
        "apiKey": "{{replace (command_output 'podman secret inspect qoder-proxy-api-key --showsecret | jq -r .[0].SecretData') '\n' ''}}"
      },
      "models": {
        "auto": { "name": "Auto" },
        "ultimate": { "name": "Ultimate" },
        "performance": { "name": "Performance" },
        "efficient": { "name": "Efficient" },
        "lite": { "name": "Lite" },
        "qmodel": { "name": "Qwen3.6-Plus" },
        "kmodel": { "name": "Kimi-K2.6" },
        "mmodel": { "name": "MiniMax-M2.7" },
        "dmodel": { "name": "DeepSeek-V4-Pro" },
        "dfmodel": { "name": "DeepSeek-V4-Flash" },
        "gm51model": { "name": "GLM-5.1" }
      }
    }
  },
  "mcp": {
    "fast-context": {
      "type": "local",
      "command": [
        "bunx",
        "fast-context-mcp"
      ],
      "environment": {
        "WINDSURF_API_KEY": "{{replace (command_output 'rbw get windsurf-api-key') '\n' ''}}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      }
    }
  },
  "permission": {
    "bash": {
      "rbw get*": "deny"
    }
  },
  "plugin": [
    "oh-my-opencode"
  ]
}
