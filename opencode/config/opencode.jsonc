{
  "$schema": "https://opencode.ai/config.json",
// {{#if opencode.default_model}}
  "model": "{{opencode.default_model}}",
// {{/if}}
  "provider": {
// {{#if (and agent.enterprise_cn_base_url agent.enterprise_cn_providers)}}
// {{#each agent.enterprise_cn_providers}}
    "{{@key}}": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "{{@key}}",
      "options": {
        "baseURL": "{{@root.agent.enterprise_cn_base_url}}",
        "apiKey": "{{this.api_key}}",
        "useDeploymentBasedUrls": true,
        "setCacheKey": true
      },
      "models": {{command_output "jq -c '.' opencode/models-cn-meta.json"}}
    }{{#unless @last}},{{/unless}}
// {{/each}}
// {{/if}}
  },
  "mcp": {
    "fast-context": {
      "type": "local",
      "command": [
        "bunx",
        "fast-context-mcp"
      ],
      "environment": {
        "WINDSURF_API_KEY": "{{replace (command_output 'rbw get windsurf-api-key') '\n' ''}}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      }
    }
  },
  "permission": {
    "bash": {
      "rbw get*": "deny"
    }
  },
  "plugin": [
    "oh-my-openagent"
  ]
}
