{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gateway-cn": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "gateway-cn",
      "options": {
        "baseURL": "{{agent.enterprise_llm_base_url}}",
        "useDeploymentBasedUrls": true,
        "apiKey": "{{replace (command_output 'rbw get enterprise-llm-api-key') '\n' ''}}",
        "setCacheKey": true
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "options": {
            "max_tokens": 800000,
            "extra_body": {
              "stream_options": { "include_usage": true }
            }
          }
        },
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "options": {
            "max_tokens": 800000,
            "extra_body": {
              "stream_options": { "include_usage": true }
            }
          }
        },
        "glm-5.1": {
          "name": "glm-5.1",
          "options": {
            "max_tokens": 800000,
            "extra_body": {
              "stream_options": { "include_usage": true }
            }
          }
        },
        "qwen3.7-max": {
          "name": "qwen3.7-max",
          "options": {
            "max_tokens": 65536,
            "extra_body": {
              "stream_options": { "include_usage": true }
            }
          }
        },
        "kimi-k2.6": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "kimi-k2.6",
          "options": {
            "max_tokens": 98304,
            "extra_body": {
              "enable_thinking": true,
              "stream_options": { "include_usage": true }
            }
          }
        }
      }
    }
  },
  "mcp": {
    "fast-context": {
      "type": "local",
      "command": [
        "bunx",
        "fast-context-mcp"
      ],
      "environment": {
        "WINDSURF_API_KEY": "{{replace (command_output 'rbw get windsurf-api-key') '\n' ''}}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      }
    }
  },
  "permission": {
    "bash": {
      "rbw get*": "deny"
    }
  },
  "plugin": [
    "oh-my-openagent"
  ]
}
