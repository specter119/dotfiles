{
  "$schema": "https://opencode.ai/config.json",
// {{#if opencode.default_model}}
  "model": "{{opencode.default_model}}",
// {{/if}}
  "provider": {{command_output "uv run .dotter/scripts/render_gateway_providers.py opencode"}},
  "mcp": {
    "fast-context": {
      "type": "local",
      "command": [
        "bunx",
        "fast-context-mcp"
      ],
      "environment": {
        "WINDSURF_API_KEY": "{{replace (command_output 'rbw get windsurf-api-key') '\n' ''}}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{replace (command_output 'rbw get context7-api-key') '\n' ''}}"
      }
    }
  },
  "permission": {
    "bash": {
      "rbw get*": "deny"
    }
  },
  "plugin": []
}
