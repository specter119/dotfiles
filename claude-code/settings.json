{
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "{{replace (command_output 'rbw get codesome-claude-sub-key') '\n' ''}}",
    "ANTHROPIC_BASE_URL": "https://cc.codesome.ai",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.local/share/cli-hooks/notify.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.config/claude/hooks/rtk-rewrite.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "opus",
  "permissions": {
    "allow": [
      "Read(**/CLAUDE.md)",
      "WebSearch",
      "WebFetch",
      "Bash(man:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(whoami:*)",
      "Bash(which:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(ncdu:*)",
      "Bash(gdu:*)",
      "Bash(dysk:*)",
      "Bash(dig:*)",
      "Bash(ss:*)",
      "Bash(ast-grep:*)",
      "Bash(jq:*)",
      "Bash(git:status,show,diff,grep,branch,tag,log,rev-parse,config)",
      "Bash(jj:*)",
      "Bash(rtk:*)",
      "Bash(xurl:*)",
      "Bash(cargo:test,build,check,clippy,fmt)",
      "Bash(mkdir:*)",
      "Bash(gh:api,repo,pr,issue,run,search)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(pre-commit:*)",
      "Bash(pdftoppm:*)",
      "Bash(playwright-cli:*)",
      "mcp__plugin_context7_context7__*",
      "mcp__morph-mcp__edit_file",
      "Skill(deep-research)",
      "Skill(genimg)",
      "Skill(onenote-wiki)",
      "Skill(report-building)",
      "Skill(slide-building)",
      "Skill(thorough-digest)",
      "Skill(typst-authoring)",
      "Skill(skill-creator)"
    ],
    "deny": [
      "Bash(rbw:get*)"
    ]
  },
  "skipWebFetchPreflight": true,
  "statusLine": {
    "command": "~/.local/bin/ccline",
    "padding": 0,
    "type": "command"
  }
}
