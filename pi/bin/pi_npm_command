#!/bin/bash
# Pi npm command wrapper: translates npm-style calls to bun equivalents.
# Logs all invocations for debugging; remove LOG line to disable.
LOG="${XDG_STATE_HOME:-$HOME/.local/state}/pi/npm-command.log"
mkdir -p "$(dirname "$LOG")"
echo "[$(date -Iseconds)] PWD=$PWD args=$*" >> "$LOG"

# Handle 'root -g' command: return bun's global node_modules path
if [[ "$1" == "root" && "$2" == "-g" ]]; then
  echo "${BUN_INSTALL_GLOBAL_DIR:-${HOME}/.bun/install/global}/node_modules"
  exit 0
fi

# Handle 'view' command: delegate to npm for version queries
if [[ "$1" == "view" ]]; then
  exec npm "$@"
fi

args=()
prefix_dir=""
is_install=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    install|add|i)
      args+=("$1" "--trust")
      is_install=true
      shift
      ;;
    --prefix)
      prefix_dir="$2"
      shift 2
      ;;
    --prefix=*)
      prefix_dir="${1#--prefix=}"
      shift
      ;;
    --save|--save-dev|--save-optional|--legacy-peer-deps|--ignore-scripts)
      # npm-only flags bun ignores or handles differently; skip
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ -n "$prefix_dir" ]]; then
  cd "$prefix_dir" || exit 1
fi

export BUN_INSTALL_TRUST=1
exec bun "${args[@]}"
